    "copy-chessboard-assets": "mkdir -p apps/chessGrid/src/assets/cm-chessboard/assets && cp -r node_modules/cm-chessboard/assets/* apps/chessGrid/src/assets/cm-chessboard/assets/",
    "deploy:all": "nx run deploy-all",
    "deploy:chessGrid": "nx run deploy-chessGrid",
    "deploy:chessColate": "nx run deploy-chessColate",
