    "serve:chessColate": "nx run chessColate:serve-static",
    "build:chessGrid": "nx build chessGrid",
    "build:chessColate": "CI=true nx build chessColate",
    "android:build": "CI=true nx build chessColate && cd apps/chessColate && npx cap sync android",
    "android:sync": "CI=true nx build chessColate && cd apps/chessColate && npx cap sync android",
    "android:open": "cd apps/chessColate && npx cap open android",
    "android:run": "cd apps/chessColate && npx cap run android",
